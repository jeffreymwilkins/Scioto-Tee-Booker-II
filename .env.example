CLUB_URL=https://www.sciotocc.com/login.aspx
USERNAME=your_username
PASSWORD=your_password
MEMBER_NAME=Your Name
TRANSPORT_MODE=C-B
TZ=America/New_York
DEBUG_SCREENSHOTS=true
HEADLESS=true
LOGIN_LEAD_MINUTES=2
NODE_ENV=production

# Durable persistence: a private GitHub Gist stores bookings.json so
# pending bookings survive Heroku dyno restarts. Leave both unset for
# local-only (file-only) operation.
#   GIST_ID:    the gist's id (the hex string after gist.github.com/<user>/)
#   GIST_TOKEN: a fine-grained PAT with "Gists: read & write" scope
GIST_ID=
GIST_TOKEN=
